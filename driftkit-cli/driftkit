#!/bin/bash

# DriftKit CLI launcher script

# Find the script location
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

# Check if JAR exists
JAR_FILE="$SCRIPT_DIR/target/driftkit-cli-0.6.0-jar-with-dependencies.jar"

if [ ! -f "$JAR_FILE" ]; then
    echo "Error: DriftKit CLI JAR not found at $JAR_FILE"
    echo "Please build the project first with: mvn package"
    exit 1
fi

# Run the CLI
java -jar "$JAR_FILE" "$@"