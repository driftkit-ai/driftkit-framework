+                "test-chat-workflow"
+            );
+            request2.setUserId(userId);
+            executionService.executeChat(request2);
+        }
+        
+        // Check memory stats
+        ChatRequest statsRequest = new ChatRequest(
+            session1.getChatId(),
+            Map.of("message", "check memory stats"),
+            Language.ENGLISH,
+            "test-chat-workflow"
