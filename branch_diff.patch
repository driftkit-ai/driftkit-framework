+                .is(CustomerTier.SILVER, flow -> flow
+                    .then(processingSteps::applySilverDiscount))
+                .otherwise(flow -> flow
+                    .then(processingSteps::applyStandardPricing))
+            .then(processingSteps::finalizeOrder)
